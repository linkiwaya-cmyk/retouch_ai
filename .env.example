# ── API server ─────────────────────────────────────────────────────────────────
# CodeFormer weights path (auto-downloaded on first run if missing)
CODEFORMER_WEIGHT=~/.cache/codeformer/codeformer.pth

# BiSeNet face-parsing weights path (auto-downloaded by facexlib on first run)
BISENET_WEIGHT=~/.cache/facexlib/parsing_bisenet.pth

# CodeFormer fidelity (0.0 = max enhancement, 1.0 = max fidelity to original)
# 0.7 is a good balance for professional retouching
CF_FIDELITY=0.7

# Face detection confidence threshold
FACE_CONF=0.5

